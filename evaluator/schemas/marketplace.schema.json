{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "type": "object",
  "required": ["apiVersion", "kind", "metadata", "spec"],
  "properties": {
    "apiVersion": { "const": "ai.anz.com/v1" },
    "kind": { "const": "AgentCapability" },
    "metadata": { "type": "object", "required": ["name", "version", "owner", "supportChannel"] },
    "spec": { "type": "object", "required": ["type", "riskLevel", "dataClassification", "runtime", "capabilities", "eval"] }
  }
}
